# GitHub Configuration
# Required: GitHub Personal Access Token or GitHub App token
# Permissions needed: pull_requests:write, contents:read, issues:write
GITHUB_TOKEN=ghp_your_github_token_here

# Repository Information (automatically set by GitHub Actions)
# Only needed for manual execution
PR_NUMBER=
REPO_OWNER=
REPO_NAME=
BASE_REF=main
HEAD_REF=
BASE_SHA=
HEAD_SHA=

# OpenAI Configuration (Optional)
# Required only if AI-powered reviews are enabled
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Logging Configuration
# Options: error, warn, info, debug
LOG_LEVEL=info

# Review Configuration Overrides (Optional)
# These override settings in review-config.yml

# Minimum severity level to post comments
# Options: critical, high, medium, low
REVIEW_MIN_SEVERITY=medium

# Auto-approve PRs that pass all checks
# Options: true, false
REVIEW_AUTO_APPROVE=false

# AI Model Selection
# Options: gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo
AI_MODEL=gpt-4

# Enable/Disable Specific Checks
ENABLE_SECURITY_CHECK=true
ENABLE_PERFORMANCE_CHECK=true
ENABLE_MAINTAINABILITY_CHECK=true
ENABLE_STYLE_CHECK=true
ENABLE_AI_REVIEW=false

# Notification Settings (Optional)
# Slack webhook URL for notifications
SLACK_WEBHOOK_URL=

# Email notification settings
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Advanced Settings
# Maximum number of files to review in a single run
MAX_FILES_TO_REVIEW=100

# Timeout for AI review requests (milliseconds)
AI_REVIEW_TIMEOUT=30000

# GitHub API rate limit handling
GITHUB_API_RETRY_ATTEMPTS=3
GITHUB_API_RETRY_DELAY=1000